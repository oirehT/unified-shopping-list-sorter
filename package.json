{
	"name": "unified-shopping-list-sorter",
	"version": "1.0.2",
	"description": "Auto-sort managed shopping lists in Obsidian.",
	"main": "main.js",
	"type": "module",
	"packageManager": "pnpm@10.33.3",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"shopping-list"
	],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@types/node": "24.12.4",
		"esbuild": "0.28.0",
		"obsidian": "1.12.3",
		"typescript": "6.0.3",
		"vitest": "4.1.7"
	},
	"pnpm": {
		"overrides": {
			"@codemirror/state": "6.5.0"
		}
	}
}
